<!--note you cannot unhash any more tasks then whats already been doen (AE: 0x1B34A56). trust me i've tried, 19 different hex formats.-->
<CTuningFile>
	<Tunables>
	    <Item type="CGrabHelper__Tunables">
      <Name>CGrabHelper</Name>
      <Sets>
        <sets>
          <Item key="Default"> <!--Overall Grab Tuneables-->
            <Id>Default</Id>
            <Priority value="0" />
            <Enabled value="true" />
            <Messages>
              <Item type="CNmMessage">
                <Name>grab</Name>
                <Params>
                  <Item type="CNmParameterFloat">
                    <Name>grabStrength</Name>
                    <Value value="200.000000" />
                  </Item>
                  <Item type="CNmParameterFloat">
                    <Name>grabDistance</Name>
                    <Value value="4.000000" />
                  </Item>
                  <Item type="CNmParameterFloat">
                    <Name>reachAngle</Name>
                    <Value value="2.000000" />
                  </Item>
                  <Item type="CNmParameterFloat">
                    <Name>oneSideReachAngle</Name>
                    <Value value="2.200000" />
                  </Item>
                  <Item type="CNmParameterFloat">
                    <Name>pullUpStrengthRight</Name>
                    <Value value="0.000000" />
                  </Item>
                  <Item type="CNmParameterFloat">
                    <Name>pullUpStrengthLeft</Name>
                    <Value value="0.000000" />
                  </Item>
                  <Item type="CNmParameterFloat">
                    <Name>pullUpTime</Name>
                    <Value value="5.000000" />
                  </Item>
                  <Item type="CNmParameterBool">
                    <Name>dontLetGo</Name>
                    <Value value="false" />
                  </Item>
				  <Item type="CNmParameterBool">
                    <Name>DropWeaponIfNecessary</Name>
                    <Value value="true" />
                  </Item>
                  <Item type="CNmParameterBool">
                    <Name>lookAtGrab</Name>
                    <Value value="true" />
                  </Item>
                  <Item type="CNmParameterRandomFloat">
                    <Name>grabHoldMaxTimer</Name>
                    <Min value="5.200000" />
                    <Max value="15.800000" />
                  </Item>
				  <Item type="CNmParameterFloat">
                    <Name>StickyHands</Name>
                    <Value value="10.0" />
                  </Item>
                </Params>
                <ForceNewMessage value="false" />
                <TaskMessage value="false" />
              </Item>
            </Messages>
          </Item>
          <Item key="GrabVehicleDoor">
            <Id>GrabVehicleDoor</Id>
            <Priority value="0" />
            <Enabled value="true" />
            <Messages>
              <Item type="CNmMessage">
                <Name>grab</Name>
                <Params>
                  <Item type="CNmParameterFloat">
                    <Name>grabStrength</Name>
                    <Value value="50.000000" />
                  </Item>
                  <Item type="CNmParameterFloat">
                    <Name>grabDistance</Name>
                    <Value value="0.500000" />
                  </Item>
                  <Item type="CNmParameterFloat">
                    <Name>reachAngle</Name>
                    <Value value="2.800000" />
                  </Item>
                  <Item type="CNmParameterFloat">
                    <Name>oneSideReachAngle</Name>
                    <Value value="1.400000" />
                  </Item>
                  <Item type="CNmParameterFloat">
                    <Name>pullUpStrengthRight</Name>
                    <Value value="2.000000" />
                  </Item>
                  <Item type="CNmParameterFloat">
                    <Name>pullUpStrengthLeft</Name>
                    <Value value="2.000000" />
                  </Item>
                  <Item type="CNmParameterFloat">
                    <Name>pullUpTime</Name>
                    <Value value="1.000000" />
                  </Item>
                  <Item type="CNmParameterBool">
                    <Name>dontLetGo</Name>
                    <Value value="false" />
                  </Item>
                  <Item type="CNmParameterBool">
                    <Name>lookAtGrab</Name>
                    <Value value="true" />
                  </Item>
                  <Item type="CNmParameterRandomFloat">
                    <Name>grabHoldMaxTimer</Name>
                    <Min value="5.500000" />
                    <Max value="50.800000" />
                  </Item>
                  <Item type="CNmParameterFloat">
                    <Name>move2Radius</Name>
                    <Value value="4.000000" />
                  </Item>
                </Params>
                <ForceNewMessage value="false" />
                <TaskMessage value="false" />
              </Item>
            </Messages>
          </Item>
          <Item key="GrabVehicleDoorOnBalanceFailed">
            <Id>GrabVehicleDoorOnBalanceFailed</Id>
            <Priority value="0" />
            <Enabled value="true" />
            <Messages>
              <Item type="CNmMessage">
                <Name>pedalLegs</Name>
                <Params>
                  <Item type="CNmParameterBool">
                    <Name>start</Name>
                    <Value value="true" />
                  </Item>
                  <Item type="CNmParameterBool">
                    <Name>hula</Name>
                    <Value value="true" />
                  </Item>
                </Params>
                <ForceNewMessage value="false" />
                <TaskMessage value="false" />
              </Item>
            </Messages>
          </Item>
        </sets>
      </Sets>
    </Item>
		<Item type="CTaskNMControl__Tunables"> <!--Settings for the pre caned death pose and other stuff-->
			<Name>CTaskNMControl</Name>
			<UNK_MEMBER_0x54113396>
				<UNK_MEMBER_0x98458144 value="false"/> <!--Is the death pose active?-->
				<OnlyAllowForShot value="false"/>
				<AllowWhenBalanced value="false"/>
				<MinHealth value="0.00000000"/>
				<MaxSpeed value="0.50000000"/> <!--This is affecting how fast the global ragdoll motions can be, Higher values = faster movement-->
				<UNK_MEMBER_0x35105B50 value="2.50000000"/> <!--Head death pose modifier?-->
				<UNK_MEMBER_0x91E058FA value="2.00000000"/> <!--Torso death pose modifier (Higher = faster)?-->
				<UNK_MEMBER_0xCE348154 value="5.00000000"/> <!--Arm death pose modifier?-->
				<UNK_MEMBER_0x8C2664D0 value="3.00000000"/> <!--Leg death pose modifier?-->
				<UNK_MEMBER_0xCD7E87D2 value="6.00000000"/> <!--Death pose chance multiplier (Higher = More likely)?-->
				<MaxUprightRatio value="0.50000000"/> <!--Max-->
				<UNK_MEMBER_0x040B42DA value="0.65000000"/> <!-- The time when the death pose is likely to occur. Higher can make falling reactions set itself into a death pose. Putting to 50.0 will set every task into a death pose. Example: Falling, Gunshots etc  -->
			</UNK_MEMBER_0x54113396>
		</Item>
		<Item type="0x10F8CDA5"> <!--Is used to apply behaviours globally to ragdolled NPCs in any situation. Can be used to increase/decrease the stability or something else-->
			<Name>0x08A0B6FA</Name>
			<UNK_MEMBER_0xDE633510 value="80.00000000"/>
			<UNK_MEMBER_0x75D89EA6 value="10.00000000"/>
			<Start> <!--Put your "global" messages in the "Start" section-->
				<Id>start</Id>
				<Priority value="0"/>
				<Enabled value="true"/>
