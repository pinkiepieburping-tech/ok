					<Item key="0x0BAC5305"> <!--staggerfall-->  <!--staggerFall kicks in to bring a NPC to the ground with a staggering motion. It will be blendet in in many situations. If you want to deactivate it for a specific task, add the staggerfall message with start = false-->
