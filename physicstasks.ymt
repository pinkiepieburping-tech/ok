                <Name>velocityScaled</Name>
                <Value value="true"/>
              </Item>
            </Params>
            <ForceNewMessage value="true"/>
            <TaskMessage value="false"/>
          </Item>
			  <Item type="CNmMessage"> <!--if they should fall to knees when shot in the head.-->
